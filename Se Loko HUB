local espHighlights = {}

-- Wallcheck function
local function isVisible(targetPart)
    if not targetPart or not targetPart.Parent then return false end
    local origin = Camera.CFrame.Position
    local dir = (targetPart.Position - origin).Unit * MAX_DIST
    
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.IgnoreWater = true
    
    local result = Workspace:Raycast(origin, dir, params)
    if not result then return true end
    
    return result.Instance:IsDescendantOf(targetPart.Parent) or 
           result.Instance.Transparency > 0.9 or 
           result.Instance.CanCollide == false
end

-- Closest enemy
local function getClosestEnemy()
    local bestPart, bestDist = nil, MAX_DIST
    local myPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myPos then return nil end
    
    for _, plr in Players:GetPlayers() do
        if plr == LocalPlayer then continue end
        if not plr.Character then continue end
        
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        
        if plr.Team and LocalPlayer.Team and plr.Team == LocalPlayer.Team then continue end
        
        local part = plr.Character:FindFirstChild(AIM_PART)
        if not part then continue end
        
        local dist3D = (part.Position - myPos.Position).Magnitude
        if dist3D > bestDist then continue end
        
        if not WALLHACK_ENABLED and not isVisible(part) then continue end
        
        bestDist = dist3D
        bestPart = part
    end
    
    return bestPart
end

-- ESP com reset periódico
local function createOrUpdateHighlight(plr)
    if not plr.Character or not plr.Character.Parent then return end
    
    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    if hum.Health > 0 and plr.Team and LocalPlayer.Team and plr.Team == LocalPlayer.Team then
        return
    end
    
    if espHighlights[plr] then
        espHighlights[plr]:Destroy()
        espHighlights[plr] = nil
    end
    
    local hl = Instance.new("Highlight")
    hl.FillTransparency = 1
    hl.OutlineTransparency = 0
    hl.OutlineColor = Color3.fromRGB(255, 0, 0)
    
    if hum.Health <= 0 then
        hl.OutlineColor = Color3.fromRGB(180, 0, 0)
    end
    
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Adornee = plr.Character
    hl.Parent = plr.Character
    espHighlights[plr] = hl
end

local lastResetTime = tick()
local RESET_INTERVAL = 3

RunService.Heartbeat:Connect(function()
    if not ESP_ENABLED then
        for _, hl in pairs(espHighlights) do
            if hl then hl:Destroy() end
        end
        espHighlights = {}
        return
    end
    
    local currentTime = tick()
    
    if currentTime - lastResetTime >= RESET_INTERVAL then
        for _, hl in pairs(espHighlights) do
            if hl then hl:Destroy() end
        end
        espHighlights = {}
        lastResetTime = currentTime
    end
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        createOrUpdateHighlight(plr)
    end
end)

Players.PlayerAdded:Connect(function(plr)
    if plr == LocalPlayer then return end
    
    plr.CharacterAdded:Connect(function()
        if not ESP_ENABLED then return end
        task.wait(0.3)
        createOrUpdateHighlight(plr)
    end)
    
    if plr.Character then
        task.wait(0.3)
        createOrUpdateHighlight(plr)
    end
end)

Players.PlayerRemoving:Connect(function(plr)
    if espHighlights[plr] then
        espHighlights[plr]:Destroy()
        espHighlights[plr] = nil
    end
end)

-- Aimbot
RunService.RenderStepped:Connect(function()
    if not AIM_ENABLED then return end
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local target = getClosestEnemy()
    if not target then return end
    
    local root = target.Parent:FindFirstChild("HumanoidRootPart")
    local predPos = target.Position
    if root and root.Velocity.Magnitude > 0 then
        predPos = predPos + root.Velocity * PREDICTION
    end
    
    local current = Camera.CFrame
    local targetCF = CFrame.lookAt(current.Position, predPos)
    
    local distToTarget = (predPos - current.Position).Magnitude
    local alpha = math.clamp(SMOOTHNESS * (1 + (distToTarget / 200)), 0.08, 0.35)
    
    Camera.CFrame = current:Lerp(targetCF, alpha)
end)

