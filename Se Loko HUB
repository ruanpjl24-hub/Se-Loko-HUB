-- Limpeza quando jogador sai
Players.PlayerRemoving:Connect(function(plr)
    if espHighlights[plr] then
        espHighlights[plr]:Destroy()
        espHighlights[plr] = nil
    end
end)

-- Loop para atualizar ESP
RunService.Heartbeat:Connect(function()
    if not ESP_ENABLED then return end
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer or not plr.Character or (plr.Team and LocalPlayer.Team and plr.Team == LocalPlayer.Team) then
            if espHighlights[plr] then
                espHighlights[plr]:Destroy()
                espHighlights[plr] = nil
            end
            continue
        end
        
        local hl = espHighlights[plr]
        if not hl or not hl.Parent then
            hl = Instance.new("Highlight")
            hl.FillTransparency = 1
            hl.OutlineTransparency = 0
            hl.OutlineColor = Color3.fromRGB(255, 0, 0)
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Adornee = plr.Character
            hl.Parent = plr.Character
            espHighlights[plr] = hl
        end
        hl.Adornee = plr.Character
    end
end)

-- Loop principal (GRUDA suave com prediction)
RunService.RenderStepped:Connect(function(dt)
    if not AIM_ENABLED then return end
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local target = getClosestEnemy()
    if not target then return end
    
    -- Prediction (prevê movimento)
    local root = target.Parent:FindFirstChild("HumanoidRootPart")
    local predPos = target.Position
    if root and root.Velocity.Magnitude > 0 then
        predPos = predPos + root.Velocity * PREDICTION
    end
    
    -- Mira GRUDENTA
    local current = Camera.CFrame
    local targetCF = CFrame.lookAt(current.Position, predPos)
    
    -- Alpha dinâmico (mais rápido se longe, suave se perto)
    local distToTarget = (predPos - current.Position).Magnitude
    local alpha = math.clamp(SMOOTHNESS * (1 + (distToTarget / 200)), 0.08, 0.35)
    
    Camera.CFrame = current:Lerp(targetCF, alpha)
end)

